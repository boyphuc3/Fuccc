def local_ip() -> str:
    sock = socket.socket(socket.AF_INET, socket.SOCK_DGRAM)
    try:
        sock.connect(("8.8.8.8", 80))
        return sock.getsockname()[0]
    except OSError:
        return "127.0.0.1"
    finally:
        sock.close()

def write_html() -> None:
    background_image = next(
        (name for name in BACKGROUND_IMAGE_CANDIDATES if (OUT_DIR / name).exists()),
        None,
    )
    audio_file = next(
        (path.name for pattern in AUDIO_CANDIDATES for path in OUT_DIR.glob(pattern) if path.is_file()),
        None,
    )
    html = HTML.replace("__BACKGROUND_IMAGE__", background_image or "")
    html = html.replace("__AUDIO_SRC__", audio_file or "")
    html = html.replace("__AUDIO_NAME__", audio_file or "")
    html = html.replace("__HAS_MUSIC__", "1" if audio_file else "0")
    HTML_FILE.write_text(html, encoding="utf-8")
    INDEX_FILE.write_text(html, encoding="utf-8")

def write_qr(url: str) -> None:
    try:
        import qrcode
    except ImportError as exc:
        raise SystemExit(
            "Thiếu thư viện qrcode. Chạy: pip install qrcode[pil]"
        ) from exc

    img = qrcode.make(url)
    img.save(QR_FILE)

def serve() -> None:
    handler = SimpleHTTPRequestHandler
    httpd = ThreadingHTTPServer(("0.0.0.0", PORT), handler)
    print(f"Server đang chạy: http://{local_ip()}:{PORT}/{HTML_FILE.name}")
    print(f"Mã QR đã lưu tại: {QR_FILE}")
    httpd.serve_forever()

def main() -> None:
    write_html()
    url = f"http://{local_ip()}:{PORT}/{HTML_FILE.name}"
    write_qr(url)

    thread = threading.Thread(target=serve, daemon=True)
    thread.start()

    print("Mở file QR để quét:")
    print(QR_FILE)
    print("Nếu quét bằng điện thoại, máy và điện thoại cần cùng Wi-Fi.")
    thread.join()

if __name__ == "__main__":
    main()
