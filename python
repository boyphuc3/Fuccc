  <script>
    const sky = document.getElementById('sky');
    const heartField = document.getElementById('heartField');
    const brand = document.querySelector('.brand');
    const brandSmoke = document.getElementById('brandSmoke');
    const bgImage = document.getElementById('bgImage');
    const bgm = document.getElementById('bgm');
    const playBtn = document.getElementById('playBtn');
    const musicChip = document.getElementById('musicChip');

    if (document.body.dataset.bg === '1') {
      bgImage.src = '__BACKGROUND_IMAGE__';
    }
    const hasMusic = document.body.dataset.music === '1';
    if (!hasMusic) {
      bgm.setAttribute('disabled', 'disabled');
    }

    function addStars(count = 72) {
      for (let i = 0; i < count; i++) {
        const star = document.createElement('div');
        star.className = 'star';
        star.style.left = Math.random() * 100 + 'vw';
        star.style.top = Math.random() * 100 + 'vh';
        star.style.setProperty('--twinkle', (2 + Math.random() * 5) + 's');
        star.style.opacity = (0.2 + Math.random() * 0.8).toFixed(2);
        star.style.transform = 'scale(' + (0.6 + Math.random() * 1.4).toFixed(2) + ')';
        sky.appendChild(star);
      }
    }

    function spawnMeteor() {
      const meteor = document.createElement('div');
      meteor.className = 'meteor';
      const startX = Math.random() * window.innerWidth * 0.8;
      const startY = Math.random() * window.innerHeight * 0.35;
      const angle = -22 - Math.random() * 20;
      const longTrail = Math.random() > 0.7;
      const dx = (longTrail ? 560 : 280) + Math.random() * (longTrail ? 520 : 380);
      const dy = (longTrail ? 330 : 210) + Math.random() * (longTrail ? 320 : 240);
      meteor.style.left = startX + 'px';
      meteor.style.top = startY + 'px';
      meteor.style.setProperty('--angle', angle + 'deg');
      meteor.style.setProperty('--dx', dx + 'px');
      meteor.style.setProperty('--dy', dy + 'px');
      meteor.style.width = (longTrail ? 260 : 180) + 'px';
      meteor.style.setProperty('--duration', (1.15 + Math.random() * (longTrail ? 1.4 : 1.0)) + 's');
      meteor.style.opacity = longTrail ? '0.95' : '0.88';
      sky.appendChild(meteor);
      meteor.addEventListener('animationend', () => meteor.remove());
    }

    function addDust(count = 12) {
      for (let i = 0; i < count; i++) {
        const dust = document.createElement('div');
        dust.className = 'star';
        dust.style.width = '1px';
        dust.style.height = '1px';
        dust.style.left = Math.random() * 100 + 'vw';
        dust.style.top = Math.random() * 100 + 'vh';
        dust.style.opacity = (0.06 + Math.random() * 0.18).toFixed(2);
        dust.style.setProperty('--twinkle', (6 + Math.random() * 8) + 's');
        dust.style.transform = 'scale(' + (0.35 + Math.random() * 0.7).toFixed(2) + ')';
        sky.appendChild(dust);
      }
    }

    function addMist(count = 4) {
      for (let i = 0; i < count; i++) {
        const mist = document.createElement('div');
        mist.className = 'star';
        mist.style.width = (18 + Math.random() * 46) + 'px';
        mist.style.height = '1px';
        mist.style.left = (Math.random() * 100) + 'vw';
        mist.style.top = (18 + Math.random() * 64) + 'vh';
        mist.style.opacity = (0.03 + Math.random() * 0.08).toFixed(2);
        mist.style.filter = 'blur(4px)';
        mist.style.setProperty('--twinkle', (10 + Math.random() * 10) + 's');
        mist.style.transform = 'rotate(' + (-10 + Math.random() * 20).toFixed(1) + 'deg)';
        sky.appendChild(mist);
      }
    }

    function emitSmokeBurst() {
      const rect = brand.getBoundingClientRect();
      const count = 36;
      for (let i = 0; i < count; i++) {
        const puff = document.createElement('div');
        puff.className = 'smoke-puff';
        const x = rect.left + rect.width * (0.08 + Math.random() * 0.84);
        const y = rect.top + rect.height * (0.2 + Math.random() * 0.6);
        const dx = (-28 + Math.random() * 56).toFixed(1) + 'px';
        const dy = (-90 - Math.random() * 170).toFixed(1) + 'px';
        puff.style.left = x + 'px';
        puff.style.top = y + 'px';
        puff.style.setProperty('--dx', dx);
        puff.style.setProperty('--dy', dy);
        puff.style.setProperty('--sc', (3.2 + Math.random() * 4.5).toFixed(2));
        puff.style.setProperty('--dur', (2.4 + Math.random() * 1.8).toFixed(2) + 's');
        puff.style.setProperty('--op', (0.18 + Math.random() * 0.35).toFixed(2));
        brandSmoke.appendChild(puff);
        puff.addEventListener('animationend', () => puff.remove());
      }
    }

    function emitHeartBurst() {
      const count = 8;
      for (let i = 0; i < count; i++) {
        const heart = document.createElement('div');
        heart.className = 'heart';
        heart.textContent = '❤';
        const spread = (Math.random() * 180 - 90).toFixed(1) + 'px';
        const rise = (-220 - Math.random() * 180).toFixed(1) + 'px';
        heart.style.left = (50 + Math.random() * 6 - 3).toFixed(2) + '%';
        heart.style.top = (76 + Math.random() * 4 - 2).toFixed(2) + '%';
        heart.style.setProperty('--dx', spread);
        heart.style.setProperty('--dy', rise);
        heart.style.setProperty('--dur', (6.4 + Math.random() * 0.7).toFixed(2) + 's');
        heart.style.setProperty('--scale', (0.9 + Math.random() * 0.7).toFixed(2));
        heart.style.setProperty('--rot', (-16 + Math.random() * 32).toFixed(1) + 'deg');
        heart.style.setProperty('--size', (12 + Math.random() * 8).toFixed(0) + 'px');
        heartField.appendChild(heart);
        heart.addEventListener('animationend', () => heart.remove());
      }
    }

    async function startMusic() {
      if (!hasMusic) return false;
      try {
        bgm.volume = 1;
        await bgm.play();
        playBtn.textContent = '⏸';
        musicChip.classList.add('playing');
        return true;
